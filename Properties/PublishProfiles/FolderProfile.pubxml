<?xml version="1.0" encoding="utf-8"?>
<!--
  Publish profile for a self-contained single-file EXE targeting Windows x64.

  Usage:
      dotnet publish -p:PublishProfile=FolderProfile

  Or from Visual Studio: Build → Publish → select "FolderProfile".
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <PublishDir>bin\Release\net8.0-windows\publish\win-x64\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>

    <!-- Self-contained: the .NET runtime is bundled; no prior .NET install required -->
    <SelfContained>true</SelfContained>

    <!-- Bundle everything (including native libs) into a single EXE -->
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>

    <!-- Optional optimisations -->
    <PublishReadyToRun>false</PublishReadyToRun>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <TrimSelf>false</TrimSelf>
  </PropertyGroup>
</Project>
